# Copia este archivo como .env y rellena los valores

# Token del bot (obtenido de @BotFather en Telegram)
TELEGRAM_BOT_TOKEN=123456789:ABCDefGHIjklMNOpqrSTUvwxYZ

# Clave API de Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Tu Telegram user ID (para que solo tú puedas usar el bot)
# Obtén tu ID enviando /start a @userinfobot en Telegram
ALLOWED_USERS=123456789

# Ruta de la base de datos SQLite (opcional, por defecto: facturas.db)
# En Railway, apúntala a un volumen persistente para no perder datos
# entre despliegues, ej: DB_PATH=/data/facturas.db
# DB_PATH=facturas.db

# ─── Google Drive (opcional) ───────────────────────────────────
# Para que el bot suba/actualice el Excel 606 en una carpeta de Drive.
# Si dejas estas dos vacías, el bot funciona igual pero solo con /exportar.

# JSON completo de la clave de la cuenta de servicio de Google Cloud.
# Pégalo tal cual (una sola línea o multilínea), incluidas las llaves { }.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}

# ID de la carpeta de Drive donde vivirá el Excel.
# Es la parte final de la URL de la carpeta:
#   https://drive.google.com/drive/folders/ESTE_ES_EL_ID
# Comparte esa carpeta con el email de la cuenta de servicio (permiso Editor).
# GDRIVE_FOLDER_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz
